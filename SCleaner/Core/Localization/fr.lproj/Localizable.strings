/* === FAQ === */
"faq.title" = "Questions fréquentes";
"faq.q1.title" = "Comment Vortex Cleaner détecte-t-il les photos en double ?";
"faq.q1.answer" = "Nous utilisons un algorithme de hachage perceptuel (dHash) qui analyse le contenu visuel de chaque photo. Cela permet d'identifier les photos identiques ou très similaires, même si elles portent des noms de fichier différents.";
"faq.q2.title" = "Mes photos sont-elles envoyées à un serveur ?";
"faq.q2.answer" = "Non. Tout le traitement est effectué localement sur votre appareil. Vos photos ne quittent jamais votre iPhone.";
"faq.q3.title" = "Que se passe-t-il lorsque je supprime des photos ?";
"faq.q3.answer" = "Les photos supprimées sont déplacées dans « Supprimés récemment » d'iOS, où elles restent disponibles pendant 30 jours avant d'être définitivement supprimées.";
"faq.q4.title" = "Qu'est-ce que la corbeille de l'application ?";
"faq.q4.answer" = "La corbeille est un espace interne où les fichiers de Downloads sont conservés pendant 30 jours avant leur suppression définitive, vous permettant de les restaurer si nécessaire.";
"faq.q5.title" = "Comment fonctionne l'abonnement ?";
"faq.q5.answer" = "Nous proposons des forfaits hebdomadaire et mensuel. Les abonnés ont un accès illimité à toutes les fonctionnalités. Résiliez à tout moment dans les réglages de l'iPhone.";
"faq.q6.title" = "Puis-je résilier mon abonnement ?";
"faq.q6.answer" = "Oui. Accédez à Réglages > votre nom > Abonnements sur votre iPhone. L'accès Premium continue jusqu'à la fin de la période payée.";
"faq.q7.title" = "L'application fonctionne-t-elle sans Internet ?";
"faq.q7.answer" = "Oui. L'analyse et la suppression fonctionnent entièrement hors ligne. Une connexion Internet n'est nécessaire que pour la gestion des abonnements.";

