/* === FAQ === */
"faq.title" = "Perguntas Frequentes";
"faq.q1.title" = "Como o Vortex Cleaner encontra fotos duplicadas?";
"faq.q1.answer" = "Utilizamos um algoritmo de hash perceptual (dHash) que analisa o conteúdo visual de cada foto. Isso permite identificar fotos idênticas ou muito semelhantes mesmo que tenham nomes diferentes.";
"faq.q2.title" = "Minhas fotos são enviadas para algum servidor?";
"faq.q2.answer" = "Não. Todo o processamento é feito localmente no seu dispositivo. Suas fotos nunca saem do seu iPhone.";
"faq.q3.title" = "O que acontece quando excluo fotos?";
"faq.q3.answer" = "As fotos excluídas são movidas para Apagados Recentemente do iOS, onde ficam disponíveis por 30 dias antes de serem excluídas permanentemente.";
"faq.q4.title" = "O que é a Lixeira do app?";
"faq.q4.answer" = "A Lixeira é um espaço interno onde arquivos de Downloads são mantidos por 30 dias antes da exclusão permanente, permitindo restaurá-los se necessário.";
"faq.q5.title" = "Como funciona a assinatura?";
"faq.q5.answer" = "Oferecemos planos semanal e mensal. Assinantes têm acesso ilimitado a todas as funcionalidades. Cancele a qualquer momento nas Configurações do iPhone.";
"faq.q6.title" = "Posso cancelar minha assinatura?";
"faq.q6.answer" = "Sim. Acesse Configurações > seu nome > Assinaturas no iPhone. O acesso Premium continua até o final do período pago.";
"faq.q7.title" = "O app funciona sem internet?";
"faq.q7.answer" = "Sim. O escaneamento e a exclusão funcionam completamente offline. A conexão é necessária apenas para gerenciar assinaturas.";

