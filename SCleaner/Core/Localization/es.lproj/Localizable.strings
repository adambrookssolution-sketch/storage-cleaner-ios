/* === FAQ === */
"faq.title" = "Preguntas Frecuentes";
"faq.q1.title" = "¿Cómo encuentra fotos duplicadas Vortex Cleaner?";
"faq.q1.answer" = "Utilizamos un algoritmo de hash perceptual (dHash) que analiza el contenido visual de cada foto. Esto permite identificar fotos idénticas o muy similares aunque tengan nombres diferentes.";
"faq.q2.title" = "¿Mis fotos se envían a algún servidor?";
"faq.q2.answer" = "No. Todo el procesamiento se realiza de forma local en su dispositivo. Sus fotos nunca salen de su iPhone.";
"faq.q3.title" = "¿Qué sucede cuando elimino fotos?";
"faq.q3.answer" = "Las fotos eliminadas se mueven a Eliminados Recientes de iOS, donde permanecen disponibles durante 30 días antes de ser eliminadas permanentemente.";
"faq.q4.title" = "¿Qué es la Papelera de la aplicación?";
"faq.q4.answer" = "La Papelera es un espacio interno donde los archivos de Downloads se conservan durante 30 días antes de la eliminación permanente, lo que le permite restaurarlos si es necesario.";
"faq.q5.title" = "¿Cómo funciona la suscripción?";
"faq.q5.answer" = "Ofrecemos planes semanal y mensual. Los suscriptores tienen acceso ilimitado a todas las funcionalidades. Cancele en cualquier momento desde los Ajustes del iPhone.";
"faq.q6.title" = "¿Puedo cancelar mi suscripción?";
"faq.q6.answer" = "Sí. Acceda a Ajustes > su nombre > Suscripciones en su iPhone. El acceso Premium continúa hasta el final del periodo pagado.";
"faq.q7.title" = "¿La aplicación funciona sin internet?";
"faq.q7.answer" = "Sí. El análisis y la eliminación funcionan completamente sin conexión. La conexión a internet solo es necesaria para gestionar suscripciones.";

