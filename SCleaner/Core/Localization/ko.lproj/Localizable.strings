/* === FAQ === */
"faq.title" = "자주 묻는 질문";
"faq.q1.title" = "Vortex Cleaner는 중복 사진을 어떻게 찾나요?";
"faq.q1.answer" = "각 사진의 시각적 내용을 분석하는 지각 해시 알고리즘(dHash)을 사용합니다. 파일 이름이 다르더라도 동일하거나 매우 유사한 사진을 식별할 수 있습니다.";
"faq.q2.title" = "제 사진이 외부 서버로 전송되나요?";
"faq.q2.answer" = "아닙니다. 모든 처리는 기기 내에서 로컬로 수행됩니다. 사진은 절대 iPhone 밖으로 전송되지 않습니다.";
"faq.q3.title" = "사진을 삭제하면 어떻게 되나요?";
"faq.q3.answer" = "삭제된 사진은 iOS의 최근 삭제된 항목으로 이동되며, 영구 삭제 전 30일간 보관됩니다.";
"faq.q4.title" = "앱 휴지통이란 무엇인가요?";
"faq.q4.answer" = "휴지통은 Downloads 파일이 영구 삭제 전 30일간 보관되는 앱 내부 공간입니다. 필요한 경우 파일을 복원하실 수 있습니다.";
"faq.q5.title" = "구독은 어떻게 작동하나요?";
"faq.q5.answer" = "주간 및 월간 요금제를 제공합니다. 구독자는 모든 기능을 무제한으로 이용하실 수 있습니다. iPhone 설정에서 언제든지 해지하실 수 있습니다.";
"faq.q6.title" = "구독을 해지할 수 있나요?";
"faq.q6.answer" = "네. iPhone에서 설정 > 본인 이름 > 구독으로 이동하세요. Premium 이용은 결제 기간이 끝날 때까지 유지됩니다.";
"faq.q7.title" = "인터넷 없이도 앱을 사용할 수 있나요?";
"faq.q7.answer" = "네. 검사와 삭제는 완전히 오프라인으로 작동합니다. 인터넷 연결은 구독 관리에만 필요합니다.";

