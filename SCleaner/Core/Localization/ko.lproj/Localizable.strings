/* === FAQ === */
"faq.title" = "자주 묻는 질문";
"faq.q1.title" = "Vortex Cleaner는 어떻게 중복 사진을 찾나요?";
"faq.q1.answer" = "각 사진의 시각적 내용을 분석하는 지각적 해싱 알고리즘(dHash)을 사용합니다. 파일 이름이 달라도 동일하거나 매우 유사한 사진을 식별할 수 있습니다.";
"faq.q2.title" = "내 사진이 서버로 전송되나요?";
"faq.q2.answer" = "아니요. 모든 처리는 기기에서 로컬로 이루어집니다. 사진은 iPhone을 벗어나지 않습니다.";
"faq.q3.title" = "사진을 삭제하면 어떻게 되나요?";
"faq.q3.answer" = "삭제된 사진은 iOS 최근 삭제 항목으로 이동되어 영구 삭제 전 30일 동안 사용 가능합니다.";
"faq.q4.title" = "앱 휴지통이란 무엇인가요?";
"faq.q4.answer" = "휴지통은 다운로드 파일이 영구 삭제 전 30일 동안 보관되는 내부 공간으로, 필요한 경우 복원할 수 있습니다.";
"faq.q5.title" = "구독은 어떻게 작동하나요?";
"faq.q5.answer" = "주간 및 월간 요금제를 제공합니다. 구독자는 모든 기능에 무제한 접근할 수 있습니다. iPhone 설정에서 언제든지 취소 가능합니다.";
"faq.q6.title" = "구독을 취소할 수 있나요?";
"faq.q6.answer" = "네. iPhone에서 설정 > 이름 > 구독으로 이동하세요. 프리미엄 접근은 결제 기간이 끝날 때까지 유지됩니다.";
"faq.q7.title" = "앱이 인터넷 없이 작동하나요?";
"faq.q7.answer" = "네. 스캔 및 삭제는 완전히 오프라인으로 작동합니다. 구독 관리에만 인터넷 연결이 필요합니다.";

