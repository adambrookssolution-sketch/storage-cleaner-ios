/* === FAQ === */
"faq.title" = "Frequently Asked Questions";
"faq.q1.title" = "How does Vortex Cleaner find duplicate photos?";
"faq.q1.answer" = "We use a perceptual hashing algorithm (dHash) that analyzes the visual content of each photo. This allows us to identify identical or very similar photos even if they have different file names.";
"faq.q2.title" = "Are my photos sent to any server?";
"faq.q2.answer" = "No. All processing is done locally on your device. Your photos never leave your iPhone.";
"faq.q3.title" = "What happens when I delete photos?";
"faq.q3.answer" = "Deleted photos are moved to iOS Recently Deleted, where they remain available for 30 days before being permanently removed.";
"faq.q4.title" = "What is the app Trash?";
"faq.q4.answer" = "The Trash is an internal space where Downloads files are kept for 30 days before permanent deletion, allowing you to restore them if needed.";
"faq.q5.title" = "How does the subscription work?";
"faq.q5.answer" = "We offer weekly and monthly plans. Subscribers have unlimited access to all features. Cancel anytime in iPhone Settings.";
"faq.q6.title" = "Can I cancel my subscription?";
"faq.q6.answer" = "Yes. Go to Settings > your name > Subscriptions on your iPhone. Premium access continues until the end of the paid period.";
"faq.q7.title" = "Does the app work without internet?";
"faq.q7.answer" = "Yes. Scanning and deletion work completely offline. An internet connection is only needed to manage subscriptions.";

