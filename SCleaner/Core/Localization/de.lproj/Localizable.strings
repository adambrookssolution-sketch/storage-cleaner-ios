/* === FAQ === */
"faq.title" = "Häufig gestellte Fragen";
"faq.q1.title" = "Wie findet Vortex Cleaner doppelte Fotos?";
"faq.q1.answer" = "Wir verwenden einen perzeptuellen Hash-Algorithmus (dHash), der den visuellen Inhalt jedes Fotos analysiert. So können identische oder sehr ähnliche Fotos erkannt werden, selbst wenn sie unterschiedliche Dateinamen haben.";
"faq.q2.title" = "Werden meine Fotos an einen Server gesendet?";
"faq.q2.answer" = "Nein. Die gesamte Verarbeitung erfolgt lokal auf Ihrem Gerät. Ihre Fotos verlassen niemals Ihr iPhone.";
"faq.q3.title" = "Was passiert, wenn ich Fotos lösche?";
"faq.q3.answer" = "Gelöschte Fotos werden in >>Zuletzt gelöscht<< von iOS verschoben. Dort bleiben sie 30 Tage lang verfügbar, bevor sie dauerhaft entfernt werden.";
"faq.q4.title" = "Was ist der Papierkorb der App?";
"faq.q4.answer" = "Der Papierkorb ist ein interner Bereich, in dem Downloads-Dateien 30 Tage lang aufbewahrt werden, bevor sie dauerhaft gelöscht werden. So können Sie sie bei Bedarf wiederherstellen.";
"faq.q5.title" = "Wie funktioniert das Abonnement?";
"faq.q5.answer" = "Wir bieten Wochen- und Monatspläne an. Abonnenten haben unbegrenzten Zugriff auf alle Funktionen. Sie können jederzeit in den iPhone-Einstellungen kündigen.";
"faq.q6.title" = "Kann ich mein Abonnement kündigen?";
"faq.q6.answer" = "Ja. Gehen Sie auf Ihrem iPhone zu >>Einstellungen<< > >>Ihr Name<< > >>Abonnements<<. Der Premium-Zugang bleibt bis zum Ende des bezahlten Zeitraums bestehen.";
"faq.q7.title" = "Funktioniert die App ohne Internet?";
"faq.q7.answer" = "Ja. Scannen und Löschen funktionieren vollständig offline. Eine Internetverbindung wird nur für die Verwaltung von Abonnements benötigt.";

