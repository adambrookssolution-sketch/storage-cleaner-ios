/* === FAQ === */
"faq.title" = "Întrebări Frecvente";
"faq.q1.title" = "Cum găsește Vortex Cleaner fotografiile duplicate?";
"faq.q1.answer" = "Utilizăm un algoritm de hash perceptual (dHash) care analizează conținutul vizual al fiecărei fotografii. Aceasta permite identificarea fotografiilor identice sau foarte similare, chiar dacă au nume diferite.";
"faq.q2.title" = "Fotografiile mele sunt trimise către vreun server?";
"faq.q2.answer" = "Nu. Toată procesarea se realizează local pe dispozitivul dumneavoastră. Fotografiile nu părăsesc niciodată iPhone-ul.";
"faq.q3.title" = "Ce se întâmplă când șterg fotografii?";
"faq.q3.answer" = "Fotografiile șterse sunt mutate în Șterse recent din iOS, unde rămân disponibile 30 de zile înainte de a fi șterse permanent.";
"faq.q4.title" = "Ce este Coșul de gunoi al aplicației?";
"faq.q4.answer" = "Coșul de gunoi este un spațiu intern unde fișierele din Downloads sunt păstrate timp de 30 de zile înainte de ștergerea permanentă, permițându-vă să le restaurați dacă este necesar.";
"faq.q5.title" = "Cum funcționează abonamentul?";
"faq.q5.answer" = "Oferim planuri săptămânal și lunar. Abonații au acces nelimitat la toate funcționalitățile. Anulați oricând din Setările iPhone.";
"faq.q6.title" = "Pot anula abonamentul?";
"faq.q6.answer" = "Da. Accesați Setări > numele dumneavoastră > Abonamente pe iPhone. Accesul Premium continuă până la sfârșitul perioadei plătite.";
"faq.q7.title" = "Aplicația funcționează fără internet?";
"faq.q7.answer" = "Da. Scanarea și ștergerea funcționează complet offline. Conexiunea la internet este necesară doar pentru gestionarea abonamentelor.";

