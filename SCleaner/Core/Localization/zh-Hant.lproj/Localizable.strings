/* === FAQ === */
"faq.title" = "常見問題";
"faq.q1.title" = "Vortex Cleaner 如何找到重複照片？";
"faq.q1.answer" = "我們使用感知雜湊演算法（dHash）來分析每張照片的視覺內容。即使檔案名稱不同，也能辨識出相同或非常相似的照片。";
"faq.q2.title" = "我的照片會被上傳到伺服器嗎？";
"faq.q2.answer" = "不會。所有處理都在您的裝置上進行。您的照片絕不會離開您的 iPhone。";
"faq.q3.title" = "刪除照片後會怎樣？";
"faq.q3.answer" = "刪除的照片會移至 iOS 的「最近刪除」，在永久刪除前保留 30 天。";
"faq.q4.title" = "什麼是 App 垃圾桶？";
"faq.q4.answer" = "垃圾桶是一個內部空間，Downloads 檔案在永久刪除前會保留 30 天，讓您在需要時可以復原。";
"faq.q5.title" = "訂閱如何運作？";
"faq.q5.answer" = "我們提供週繳和月繳方案。訂閱者可無限制使用所有功能。您可隨時在 iPhone 設定中取消。";
"faq.q6.title" = "我可以取消訂閱嗎？";
"faq.q6.answer" = "可以。請前往 iPhone 的設定 > 您的名稱 > 訂閱項目。Premium 存取將持續到付費期間結束。";
"faq.q7.title" = "App 可以在沒有網路的情況下使用嗎？";
"faq.q7.answer" = "可以。掃描和刪除功能完全可離線使用。只有管理訂閱時才需要網路連線。";

